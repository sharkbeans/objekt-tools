# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env — it is git-ignored.

# ─── Postgres ────────────────────────────────────────────────────────────────
# Password for the Postgres container. Used in DATABASE_URL below.
POSTGRES_PASSWORD="<your-strong-postgres-password>"

# Name of the secondary database that stores the local indexer mirror.
# docker/postgres/init/01-create-mirror-db.sh creates this automatically on a
# fresh Postgres volume.
MIRROR_POSTGRES_DB="indexer_mirror"

# Full connection string. With Docker Compose the host is the service name "postgres".
# Use sslmode=disable for the internal Docker network (no TLS between containers needed).
DATABASE_URL="postgresql://postgres:<your-strong-postgres-password>@postgres:5432/objekt_trade?sslmode=disable"

# ─── Redis ───────────────────────────────────────────────────────────────────
# The app connects to redis://redis:6379 automatically inside the compose network.
# No extra env var needed here; set it explicitly only if using an external Redis.
# REDIS_URL="redis://<host>:6379"

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (e.g. https://trade.yourdomain.com)
NEXT_PUBLIC_APP_URL="https://<your-domain>"

# ─── Auth (Better Auth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="<generate-with-openssl-rand-hex-32>"
# Must match NEXT_PUBLIC_APP_URL — used to validate auth callbacks
BETTER_AUTH_URL="https://<your-domain>"

# ─── Discord OAuth ───────────────────────────────────────────────────────────
# From: https://discord.com/developers/applications → your app → OAuth2
DISCORD_CLIENT_ID="<your-discord-oauth-client-id>"
DISCORD_CLIENT_SECRET="<your-discord-oauth-client-secret>"

# ─── Discord Bot ─────────────────────────────────────────────────────────────
# From: https://discord.com/developers/applications → your app → Bot → Token
# Required for DM notifications via notify().
DISCORD_BOT_TOKEN="<your-discord-bot-token>"

# Discord community server invite link
DISCORD_INVITE_URL="https://discord.gg/<your-invite-code>"

# Discord server (guild) ID — right-click server icon → Copy Server ID
DISCORD_GUILD_ID="<your-discord-guild-id>"

# ─── Local rembg (Proofshot Frame) ───────────────────────────────────────────
# Internal rembg HTTP service. Keep this server-side only.
REMBG_SERVICE_URL="http://rembg:7000"
REMBG_MODEL="u2net_human_seg"

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret header value for /api/cron/* routes. Generate with: openssl rand -hex 32
CRON_SECRET="<generate-with-openssl-rand-hex-32>"

# ─── Indexer DB (optional) ───────────────────────────────────────────────────
# Read-only secondary Postgres for Cosmo ownership/transfer lookups.
# Leave blank if not used.
INDEXER_DATABASE_URL=""

# ─── Indexer mirror (optional) ───────────────────────────────────────────────
# Local mirror of the indexer's collection table, kept in sync by
# /api/cron/sync-indexer. The DB itself is auto-created by Compose on a fresh
# Postgres volume; point this at that secondary DB when the mirror is ready to
# be used by the app.
MIRROR_DATABASE_URL="postgresql://postgres:<your-strong-postgres-password>@postgres:5432/indexer_mirror?sslmode=disable"

# ─── Indexer pgbouncer sidecar (optional, disabled by default) ───────────────
# Isolates the remote indexer connection in its own container/network
# namespace, defending against the app container's outbound network path
# breaking independently of the host's. See
# docs/plans/indexer-pgbouncer-sidecar.md for what this does and doesn't fix
# — it relocates the remote network hop, it does not remove it.
#
# The "indexer-pgbouncer" service is profile-gated and does NOT start with a
# plain `docker compose up`. To cut over:
#   1. Fill in INDEXER_UPSTREAM_* with the real remote indexer's connection
#      parts (split out of what would otherwise be one INDEXER_DATABASE_URL).
#   2. Point INDEXER_DATABASE_URL (above) at
#      postgres://<user>:<pass>@indexer-pgbouncer:5432/<db> — no sslmode=
#      needed there; TLS to the real remote is handled by the bouncer via
#      INDEXER_UPSTREAM_SSLMODE.
#   3. Start with: docker compose --profile indexer-bouncer up -d
INDEXER_UPSTREAM_HOST=""
INDEXER_UPSTREAM_PORT="5432"
INDEXER_UPSTREAM_USER=""
INDEXER_UPSTREAM_PASSWORD=""
INDEXER_UPSTREAM_DB=""
# prefer | require | verify-ca | verify-full | disable — match what the real
# remote indexer actually needs.
INDEXER_UPSTREAM_SSLMODE="prefer"

# AES-256 key (base64) used to encrypt the Cosmo refresh-token payload.
# Required for nickname resolution (/api/progress, /api/objekts/by-nickname).
COSMO_KEY=""

# ─── Pusher (optional) ───────────────────────────────────────────────────────
# Realtime updates. Leave all blank to fall back to polling.
# From: https://dashboard.pusher.com → your app → App Keys
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""
