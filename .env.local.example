# Copy this file to `.env.development.local` for local development.
# Keep preview and production pulls in `.env.preview.local` and `.env.production.local`.
# Do not use `.env.local` as a shared catch-all in this repo.

# ============================================================
# Core local app config
# ============================================================
# Local Postgres example:
#   postgresql://postgres:postgres@127.0.0.1:5432/objekt_trade?sslmode=disable
# Managed Postgres example:
#   postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/objekt_trade?sslmode=disable"

# Local Redis example:
#   redis://127.0.0.1:6379
REDIS_URL="redis://127.0.0.1:6379"

# Generate a long random string for local auth/session signing.
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# Discord OAuth
# ============================================================
# Required for the normal sign-in flow used by this app.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ============================================================
# Optional local integrations
# ============================================================
# External indexer database for ownership / transfer lookups.
INDEXER_DATABASE_URL=""

# AES-256 key (base64) used to encrypt the Cosmo refresh-token payload.
# Required for nickname resolution (/api/progress, /api/objekts/by-nickname).
COSMO_KEY=""

# Discord bot token for DM notifications.
DISCORD_BOT_TOKEN=""

# Local rembg service for Proofshot Frame background removal.
# Docker compose uses http://rembg:7000. Local dev outside Docker can use http://127.0.0.1:7000.
REMBG_SERVICE_URL="http://127.0.0.1:7000"
REMBG_MODEL="u2net_human_seg"

# Pusher for realtime updates. Leave blank to fall back to polling.
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Optional if you want to call the cron route manually.
CRON_SECRET=""

# ============================================================
# Operational metadata
# ============================================================
# Not currently read by the app at runtime, but useful for team ops docs.
DISCORD_INVITE_URL=""
DISCORD_GUILD_ID=""
