# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.codex
.agents/
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.docker.example
*.env
*.env.*
!.env.*.example

# local secrets / tokens / account exports
*token*.json
*tokens*.json
*credential*.json
*credentials*.json
*secret*.json
cosmo-token*
cosmo-tokens*
session-token*
session-tokens*

# local test/dev scratch files
/tmp/
/temp/
/.tmp/
/.temp/
/local/
/data/
/exports/
/screenshots/
/recordings/

# local indexer/database dumps
/indexer-data/
/indexer-dumps/
/indexer-export*/
*.sqlite
*.sqlite3
*.db
*.dump
*.backup

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# markdowns
*.md
!README.md
